<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Push notifications (API 33+ runtime permission; requested at the notif step / before
         push registration). Pre-33 devices grant it at install. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Camera capture in the artist wizard's cover/gallery steps (TakePicture/CaptureVideo),
         requested just-in-time. Feature marked not-required so the app still installs on a
         camera-less device (it falls back to the photo/video library pickers). -->
    <uses-permission android:name="android.permission.CAMERA" />
    <uses-feature android:name="android.hardware.camera.any" android:required="false" />
    <!-- Calendar mirror (CalendarSyncService): mirror confirmed gigs into the device
         calendar + read busy/clash days. Both requested just-in-time from the Profile
         calendar-sync toggle; the zero-permission AddToCalendarButton needs neither. -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" />

    <application
        android:name=".ArtistantApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="false"
        android:theme="@style/Theme.Artistant">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.Artistant">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- OAuth callback (Google/Apple external-browser return). Must match the
                 supabase-kt Auth { scheme; host } config AND the Supabase dashboard's
                 Additional Redirect URLs: in.artistant.app://login-callback -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />
                <data android:scheme="in.artistant.app" android:host="login-callback" />
            </intent-filter>
        </activity>

        <!-- FCM receiver (push P2b): Firebase routes new tokens + incoming data-only messages
             here. The intent-filter is the required FCM binding. -->
        <service
            android:name=".platform.push.ArtistantMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        <!-- Fallback channel FCM would use only if a system-composed `notification`-block message
             ever arrived. We send data-only + compose ourselves, so this is just to silence FCM's
             "no default channel" runtime warning; it points at an already-declared channel. -->
        <meta-data
            android:name="com.google.firebase.messaging.default_notification_channel_id"
            android:value="messages" />

        <!-- Remove WorkManager's default startup initializer so the app's
             Configuration.Provider (with the HiltWorkerFactory) is used on the
             first WorkManager.getInstance(...). Required for @HiltWorker. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- FileProvider for camera capture: gives the system camera a writable content:// uri
             under cacheDir/wizard-capture/. Authority matches WizardMediaPickers.createCaptureUri
             ("${applicationId}.fileprovider"). -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>
</manifest>
